    static void ResetGenericInstanceClass(Il2CppClass* klass)
    {
        if (klass->methods)
        {
            for (uint16_t m = 0; m < klass->method_count; m++)
            {
                MethodInfo* method = const_cast<MethodInfo*>(klass->methods[m]);
                if (method)
                    method->interpData = nullptr;
            }
        }

        klass->methods = nullptr;
        klass->fields = nullptr;
        klass->implementedInterfaces = nullptr;
        klass->interfaceOffsets = nullptr;
        klass->typeHierarchy = nullptr;
        klass->properties = nullptr;
        klass->events = nullptr;
        klass->nestedTypes = nullptr;
        klass->rgctx_data = nullptr;
        klass->static_fields = nullptr;
        klass->gc_desc = nullptr;

        klass->is_vtable_initialized = 0;
        klass->size_init_pending = 0;
        klass->size_inited = 0;
        klass->initialized = 0;
        klass->initialized_and_no_error = 0;
        klass->init_pending = 0;
        klass->initializationExceptionGCHandle = 0;
        klass->cctor_started = 0;
        klass->cctor_finished_or_no_cctor = !klass->has_cctor;
        klass->cctor_thread = 0;
    }

    void GenericClass::ResetGenericInstanceCaches(const Il2CppImage* image, bool resolveRelations)
    {
        os::FastAutoLock lock(&g_MetadataLock);

        std::vector<Il2CppGenericClassSet::iterator> toRehash;
        std::vector<Il2CppGenericClassSet::iterator> toErase;
        for (Il2CppGenericClassSet::iterator it = s_GenericClassSet.begin(); it != s_GenericClassSet.end(); it++)
        {
            Il2CppGenericClass* gclass = (*it).key;
            Il2CppClass* klass = gclass->cached_class;
            if (!klass)
                continue;

            // Only reset generic instances whose type definition belongs to the
            // hot-update image being reloaded. AOT generic instances (e.g.
            // Dictionary<string,object>) must be left untouched — they are
            // actively used by the reload code path itself and resetting their
            // caches causes crashes.
            if (klass->image != image)
                continue;

            if (gclass->type->type != IL2CPP_TYPE_CLASS && gclass->type->type != IL2CPP_TYPE_VALUETYPE)
                continue;

            const Il2CppTypeDefinition* oldTypeDefinition = reinterpret_cast<const Il2CppTypeDefinition*>(gclass->type->data.typeHandle);
            const char* oldNs = il2cpp::vm::GlobalMetadata::GetStringFromIndex(oldTypeDefinition->namespaceIndex);
            const char* oldName = il2cpp::vm::GlobalMetadata::GetStringFromIndex(oldTypeDefinition->nameIndex);
            Il2CppMetadataTypeHandle newTypeHandle = il2cpp::vm::Image::TypeHandleFromName(image, oldNs, oldName);
            if (!newTypeHandle)
                continue;

            Il2CppClass* definition = il2cpp::vm::GlobalMetadata::GetTypeInfoFromHandle(newTypeHandle);
            if (!definition || definition->image != image)
                continue;

            if (klass->method_count != definition->method_count ||
                klass->field_count != definition->field_count ||
                klass->property_count != definition->property_count ||
                klass->event_count != definition->event_count ||
                klass->interfaces_count != definition->interfaces_count ||
                klass->interface_offsets_count != definition->interface_offsets_count ||
                klass->vtable_count != definition->vtable_count)
            {
                gclass->cached_class = nullptr;
                toErase.push_back(it);
                continue;
            }

            gclass->type = &definition->byval_arg;
            klass->image = definition->image;
            klass->name = definition->name;
            klass->namespaze = definition->namespaze;
            klass->flags = definition->flags;
            klass->generic_class = gclass;
            klass->this_arg.type = klass->byval_arg.type = IL2CPP_TYPE_GENERICINST;
            klass->this_arg.data.generic_class = klass->byval_arg.data.generic_class = gclass;
            klass->this_arg.byref = true;
            klass->byval_arg.valuetype = definition->byval_arg.valuetype;
            klass->event_count = definition->event_count;
            klass->field_count = definition->field_count;
            klass->interfaces_count = definition->interfaces_count;
            klass->interface_offsets_count = definition->interface_offsets_count;
            klass->vtable_count = definition->vtable_count;
            klass->method_count = definition->method_count;
            klass->property_count = definition->property_count;
            klass->enumtype = definition->enumtype;
            klass->element_class = klass->castClass = klass;
            klass->has_cctor = definition->has_cctor;
            klass->has_finalize = definition->has_finalize;
            klass->native_size = klass->thread_static_fields_offset = -1;
            klass->token = definition->token;
            klass->interopData = MetadataCache::GetInteropDataForType(&klass->byval_arg);
            klass->is_import_or_windows_runtime = definition->is_import_or_windows_runtime;
            if (resolveRelations)
            {
                Il2CppGenericContext* context = &gclass->context;
                klass->parent = definition->parent ? Class::FromIl2CppType(metadata::GenericMetadata::InflateIfNeeded(&definition->parent->byval_arg, context, false)) : nullptr;
                klass->declaringType = definition->declaringType ? Class::FromIl2CppType(metadata::GenericMetadata::InflateIfNeeded(&definition->declaringType->byval_arg, context, false)) : nullptr;
                if (GenericClass::GetTypeDefinition(gclass) == il2cpp_defaults.generic_nullable_class)
                {
                    klass->element_class = klass->castClass = Class::FromIl2CppType(gclass->context.class_inst->type_argv[0]);
                    klass->nullabletype = true;
                }
                else
                {
                    klass->nullabletype = false;
                }
                if (klass->enumtype)
                    klass->element_class = klass->castClass = definition->element_class;
            }
            else
            {
                klass->parent = nullptr;
                klass->declaringType = nullptr;
                klass->nullabletype = false;
            }

            // Drop lazily-built caches so the next Class::Init rebuilds them from
            // the current metadata, but keep cached_class and the Il2CppClass*
            // itself to preserve generic-instance class identity across reloads.
            ResetGenericInstanceClass(klass);
            toRehash.push_back(it);
        }

        for (Il2CppGenericClassSet::iterator it : toErase)
            s_GenericClassSet.erase(it);

        for (Il2CppGenericClassSet::iterator it : toRehash)
        {
            Il2CppGenericClass* gclass = (*it).key;
            s_GenericClassSet.erase(it);
            s_GenericClassSet.insert(gclass);
        }
    }
