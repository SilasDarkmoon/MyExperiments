        
        if (assph)
        {
            il2cpp::vm::Image::ClassFromName(image2, "", "<Module>"); // to initialize nameToClassHashTable
            Il2CppImage* imageph = assph->image;
            memcpy(assph, ass, sizeof(Il2CppAssembly));
            assph->image = imageph;
            memcpy(imageph, image2, sizeof(Il2CppImage));
            imageph->assembly = assph;
            imageph->name = CopyString(image2->name);
            imageph->nameNoExt = CopyString(image2->nameNoExt);

            // Replace placeholder assembly pointer with the new assembly in s_cliAssemblies
            auto& cliAssemblies = il2cpp::vm::MetadataCache::GetCliAssembliesRef();
            for (auto& assEntry : cliAssemblies)
            {
                if (assEntry->aname.name && std::strcmp(assEntry->aname.name, nameNoExt) == 0)
                {
                    assEntry = ass;
                    break;
                }
            }
            // Replace placeholder assembly pointer in s_Assemblies
            il2cpp::vm::Assembly::ReplaceLoadedAssembly(nameNoExt, ass);
        }
