	// Returns the UnityEngine.Object Il2CppClass*, or nullptr if it cannot be
	// resolved (e.g. UnityEngine assembly not yet loaded). Cached after first
	// successful resolution.
	static Il2CppClass* GetUnityEngineObjectClass()
	{
		static Il2CppClass* s_unityObjectClass = nullptr;
		if (s_unityObjectClass)
			return s_unityObjectClass;
		const Il2CppAssembly* unityAss = il2cpp::vm::Assembly::GetLoadedAssembly("UnityEngine.CoreModule");
		if (!unityAss)
			unityAss = il2cpp::vm::Assembly::GetLoadedAssembly("UnityEngine");
		if (!unityAss || !unityAss->image)
			return nullptr;
		s_unityObjectClass = il2cpp::vm::Class::FromName(unityAss->image, "UnityEngine", "Object");
		return s_unityObjectClass;
	}

	// Compares the structural signature (field count/name/type-name and method
	// count/name) of two already-Init'd Il2CppClass objects. Returns true when
	// they are structurally identical, meaning the old Il2CppClass* can safely be
	// reused for the reloaded type.
	static bool IsClassStructurallyCompatible(Il2CppClass* oldKlass, Il2CppClass* newKlass)
	{
		if (oldKlass->field_count != newKlass->field_count)
			return false;
		if (oldKlass->method_count != newKlass->method_count)
			return false;
		if (oldKlass->vtable_count != newKlass->vtable_count)
			return false;
		if (oldKlass->interfaces_count != newKlass->interfaces_count)
			return false;
		if (oldKlass->interface_offsets_count != newKlass->interface_offsets_count)
			return false;
		if (oldKlass->instance_size != newKlass->instance_size)
			return false;
		if (oldKlass->actualSize != newKlass->actualSize)
			return false;

		for (uint16_t f = 0; f < oldKlass->field_count; f++)
		{
			const FieldInfo& of = oldKlass->fields[f];
			const FieldInfo& nf = newKlass->fields[f];
			if (!of.name || !nf.name || std::strcmp(of.name, nf.name) != 0)
				return false;
			// Compare field type by resolved type name (Il2CppType* pointers differ
			// across images, so identity comparison is not usable).
			Il2CppClass* ofType = il2cpp::vm::Class::FromIl2CppType(of.type, false);
			Il2CppClass* nfType = il2cpp::vm::Class::FromIl2CppType(nf.type, false);
			if (!ofType || !nfType)
				return false;
			if (of.type->type != nf.type->type)
				return false;
			if (of.offset != nf.offset)
				return false;
			if (std::strcmp(il2cpp::vm::Class::GetName(ofType), il2cpp::vm::Class::GetName(nfType)) != 0)
				return false;
		}

		for (uint16_t m = 0; m < oldKlass->method_count; m++)
		{
			const MethodInfo* om = oldKlass->methods[m];
			const MethodInfo* nm = newKlass->methods[m];
			if (!om || !nm || !om->name || !nm->name)
				return false;
			if (std::strcmp(om->name, nm->name) != 0)
				return false;
			if (om->parameters_count != nm->parameters_count)
				return false;
			if (om->slot != nm->slot)
				return false;
		}

		return true;
	}

	void InterpreterImage::ReuseClassListFromPreviousLoad(Il2CppImage* il2cppImage)
	{
		// On dirty reload a fresh InterpreterImage is created with an all-null
		// _classList, so type lookups create brand-new Il2CppClass objects.
		// Unity native registers MonoBehaviour ScriptingClasses keyed by
		// Il2CppClass* and only scans each Il2CppImage* once. Because the
		// placeholder's Il2CppImage* is reused (Unity cached it at registration
		// time), Unity will not re-scan, leaving the new Il2CppClass objects
		// unregistered — AddComponent<MonoBehaviour>() returns null.
		//
		// Fix: for types derived from UnityEngine.Object (the ones Unity native
		// caches by Il2CppClass*), reuse the SAME Il2CppClass* from the previous
		// load so Unity's registrations remain valid — but ONLY when the type is
		// structurally unchanged (same fields, same method count). All other
		// types are dropped (left null) and re-created lazily from the new IL.
		//
		// Method bodies of reused classes still update: they are resolved through
		// klass->image->token which now points to this new InterpreterImage. We
		// clear the cached interpData so methods re-transform from the new IL.

		// Find the most recent previous InterpreterImage sharing the same Il2CppImage*.
		InterpreterImage* prev = nullptr;
		for (uint32_t i = 0; i < kMaxMetadataImageCount; i++)
		{
			InterpreterImage* img = s_images[i];
			if (!img || img == this)
				continue;
			if (img->_il2cppImage == il2cppImage && !img->_classList.empty())
			{
				if (!prev || img->_index > prev->_index)
					prev = img;
			}
		}
		if (!prev)
			return;

		Il2CppClass* unityObjectClass = GetUnityEngineObjectClass();
		if (!unityObjectClass)
		{
			// Cannot classify UnityEngine.Object-derived types; reuse nothing.
			return;
		}

		// Reuse selectively, keyed by type full name (row index may differ across
		// versions when types are added/removed/reordered).
		//
		// NOTE: iterate over a snapshot of prev->_classList indices. prev is a
		// DIFFERENT container from this->_classList (which we mutate below), so
		// there is no iterator invalidation, but taking the size once keeps the
		// bound stable and makes the traversal obviously finite.
		il2cpp::utils::Logging::Write("[HybridCLR][DirtyReload] begin class reuse: prev image _index=%u, prev classes=%u",
			prev->_index, (uint32_t)prev->_classList.size());
		uint32_t reusedCount = 0;
		for (size_t ci = 0, cn = prev->_classList.size(); ci < cn; ci++)
		{
			Il2CppClass* oldKlass = prev->_classList[ci];
			if (!oldKlass)
				continue;

			// Only reuse classes actually produced by prev's image. A reused
			// class stored in prev->_classList from an even earlier load would
			// have a different image; skip it to avoid touching foreign metadata.
			if (oldKlass->image != prev->_il2cppImage)
				continue;

			// Only UnityEngine.Object-derived types need pointer stability.
			// oldKlass is fully initialized from a previous load, so HasParent
			// (which only walks the already-built parent chain) is safe here.
			if (!il2cpp::vm::Class::HasParent(oldKlass, unityObjectClass))
				continue;

			// Locate the same type (by namespace + name) in this (new) image.
			int32_t newRawIndex = -1;
			const char* oldNs = il2cpp::vm::Class::GetNamespace(oldKlass);
			const char* oldName = il2cpp::vm::Class::GetName(oldKlass);
			for (uint32_t i = 0, n = (uint32_t)_classList.size(); i < n; i++)
			{
				const Il2CppTypeDefinition* td = &_typesDefines[i];
				const char* ns = il2cpp::vm::GlobalMetadata::GetStringFromIndex(td->namespaceIndex);
				const char* nm = il2cpp::vm::GlobalMetadata::GetStringFromIndex(td->nameIndex);
				if (ns && nm && oldNs && oldName
					&& std::strcmp(ns, oldNs) == 0 && std::strcmp(nm, oldName) == 0)
				{
					newRawIndex = (int32_t)i;
					break;
				}
			}

			if (newRawIndex < 0)
			{
				// Type removed in the new version. Its old Il2CppClass* is leaked
				// (still referenced by Unity/GC), but it is no longer produced by
				// this image. Nothing to reuse.
				continue;
			}

			// Build the new Il2CppClass to compare structure.
			Il2CppClass* newKlass = GetTypeInfoFromTypeDefinitionRawIndex((uint32_t)newRawIndex);
			if (!newKlass)
				continue;

			// IMPORTANT: do NOT call Class::Init(newKlass) here.
			//
			// This runs inside Assembly::Create, BEFORE this new image is
			// registered (RegisterInterpreterAssembly runs afterwards). A full
			// Class::Init would trigger SetupVTable / SetupTypeHierarchy /
			// SetupGCDescriptor (which walk the parent chain) / SetupFields /
			// static-ctor bookkeeping on a type whose Il2CppImage is not yet
			// visible to the metadata subsystem, and whose _classList slot is
			// about to be overwritten with the reused oldKlass a few lines
			// below. In dirty-reload scenarios with inheriting UnityEngine.Object
			// derived types this can produce a parent chain that mixes old/new
			// Il2CppClass objects and makes the hierarchy/GC-bitmap walkers spin
			// (observed as a hang on the SECOND load).
			//
			// For reuse we only need the methods array (structural compare +
			// per-index MethodInfo rebind) and the fields array (structural
			// compare). Set those up lazily and cheaply instead of a full Init.
			// oldKlass is already fully initialized from the first load, so
			// SetupMethods/SetupFields on it are no-ops (guarded by klass->methods
			// / klass->size_inited).
			il2cpp::vm::Class::SetupMethods(oldKlass);
			il2cpp::vm::Class::SetupFields(oldKlass);
			il2cpp::vm::Class::SetupMethods(newKlass);
			il2cpp::vm::Class::SetupFields(newKlass);

			if (!IsClassStructurallyCompatible(oldKlass, newKlass))
			{
				il2cpp::utils::Logging::Write(
					"[HybridCLR][DirtyReload] structural change detected for UnityEngine.Object-derived type '%s.%s'; discarding Il2CppClass reuse (Unity native cache may become stale).",
					oldNs ? oldNs : "", oldName ? oldName : "");
				// Keep the freshly created newKlass in _classList (already set by
				// GetTypeInfoFromTypeDefinitionRawIndex); do NOT reuse the old one.
				continue;
			}

			// Structurally compatible: reuse the old Il2CppClass* so Unity native
			// registrations (keyed by Il2CppClass*) stay valid. But the reused
			// Il2CppClass and its MethodInfo objects were built for the PREVIOUS
			// InterpreterImage: their metadata pointers (methodMetadataHandle,
			// parameters, return_type, token, ...) all reference the old image's
			// metadata pool. Simply clearing interpData is NOT enough — method
			// resolution (e.g. GetMethodInfoFromMethodDef / ResolveMethodDefinition,
			// invoked when Unity or interpreted IL calls a MonoBehaviour method)
			// matches MethodInfo::methodMetadataHandle against the NEW image's
			// Il2CppMethodDefinition* by pointer identity. Since the reused
			// MethodInfo still points at the old image's definition, the match
			// fails and a MissingMethodException ("MethodNotFind ...") is thrown.
			//
			// Fix: keep the SAME Il2CppClass* / MethodInfo* objects (pointer
			// identity preserved for Unity/GC and any cached references) but
			// re-bind their contents to this new image. We do this by copying the
			// freshly built newKlass's metadata fields onto the reused objects.
			//
			// Note: this runs inside Assembly::Create which already holds
			// g_MetadataLock, so no additional locking is taken here.

			// Publish the reused class in the NEW image before rebinding its
			// Il2CppType/typeMetadataHandle. After the rebind, resolving
			// oldKlass->byval_arg must return oldKlass from this image's _classList,
			// not the temporary newKlass nor the previous image's class.
			_classList[newRawIndex] = oldKlass;

			// Rebind class-level metadata first. Method resolution often starts from
			// method->klass->byval_arg or object->klass->byval_arg; if these still
			// point to the previous image's Il2CppTypeDefinition, ResolveMethodDefinition
			// finds an old methodDef, while the MethodInfo array has been rebound to
			// the new methodDef handles, causing MethodNotFind by pointer mismatch.
			// Rebind class-level metadata to THIS image so all later lookups
			// (vtable, interface offset, field, method) resolve against the new
			// metadata pool, not the previous one.
			oldKlass->image = newKlass->image;
			oldKlass->name = newKlass->name;
			oldKlass->namespaze = newKlass->namespaze;
			oldKlass->byval_arg = newKlass->byval_arg;
			oldKlass->this_arg = newKlass->this_arg;
			oldKlass->typeMetadataHandle = newKlass->typeMetadataHandle;
			oldKlass->genericContainerHandle = newKlass->genericContainerHandle;
			oldKlass->flags = newKlass->flags;
			oldKlass->token = newKlass->token;
			oldKlass->method_count = newKlass->method_count;
			oldKlass->property_count = newKlass->property_count;
			oldKlass->field_count = newKlass->field_count;
			oldKlass->event_count = newKlass->event_count;
			oldKlass->nested_type_count = newKlass->nested_type_count;
			oldKlass->vtable_count = newKlass->vtable_count;
			oldKlass->interfaces_count = newKlass->interfaces_count;
			oldKlass->interface_offsets_count = newKlass->interface_offsets_count;

			// Sizes / layout and bitfield-derived flags copied from the new type
			// definition. parent / declaringType / castClass / element_class are
			// intentionally left as-is: for a UnityEngine.Object-derived type the
			// parent is either a codegen class (stable across loads) or another
			// reused UO type that already shares the same Il2CppClass* pointer, so
			// the existing first-load values are already correct.
			oldKlass->instance_size = newKlass->instance_size;
			oldKlass->actualSize = newKlass->actualSize;
			oldKlass->native_size = newKlass->native_size;
			oldKlass->static_fields_size = newKlass->static_fields_size;
			oldKlass->thread_static_fields_size = newKlass->thread_static_fields_size;
			oldKlass->packingSize = newKlass->packingSize;
			oldKlass->enumtype = newKlass->enumtype;
			oldKlass->is_generic = newKlass->is_generic;
			oldKlass->has_finalize = newKlass->has_finalize;
			oldKlass->has_cctor = newKlass->has_cctor;
			oldKlass->is_blittable = newKlass->is_blittable;
			oldKlass->is_import_or_windows_runtime = newKlass->is_import_or_windows_runtime;
			oldKlass->is_byref_like = newKlass->is_byref_like;
			oldKlass->interopData = newKlass->interopData;

			// Rebind field metadata in place. FieldInfo carries parent/type pointers
			// from the old image; later field/member resolution has the same pointer
			// identity problem as methods. In-place rebind keeps the FieldInfo* stable
			// (Unity / codegen may cache it) while pointing its contents at the new image.
			if (oldKlass->fields && newKlass->fields
				&& oldKlass->field_count == newKlass->field_count)
			{
				for (uint16_t f = 0; f < oldKlass->field_count; f++)
				{
					FieldInfo& oldField = oldKlass->fields[f];
					const FieldInfo& newField = newKlass->fields[f];
					oldField.name = newField.name;
					oldField.type = newField.type;
					oldField.offset = newField.offset;
					oldField.token = newField.token;
					oldField.parent = oldKlass;
				}
			}

			// Rebind each reused MethodInfo in place to the new image's metadata.
			// The structural-compatibility check above guarantees identical method
			// count and per-index correspondence (same name / parameter count).
			// Keeping the same MethodInfo* objects preserves pointer identity for any
			// cached references while the contents now reference this image's pool.
			if (oldKlass->methods && newKlass->methods
				&& oldKlass->method_count == newKlass->method_count)
			{
				for (uint16_t m = 0; m < oldKlass->method_count; m++)
				{
					MethodInfo* oldMethod = const_cast<MethodInfo*>(oldKlass->methods[m]);
					const MethodInfo* newMethod = newKlass->methods[m];
					if (!oldMethod || !newMethod)
						continue;

					// Copy all metadata-derived fields from the freshly built
					// MethodInfo (which references THIS image's metadata pool).
					oldMethod->methodPointer = newMethod->methodPointer;
					oldMethod->virtualMethodPointer = newMethod->virtualMethodPointer;
					oldMethod->methodPointerCallByInterp = newMethod->methodPointerCallByInterp;
					oldMethod->virtualMethodPointerCallByInterp = newMethod->virtualMethodPointerCallByInterp;
					oldMethod->initInterpCallMethodPointer = newMethod->initInterpCallMethodPointer;
					oldMethod->invoker_method = newMethod->invoker_method;
					oldMethod->name = newMethod->name;
					oldMethod->return_type = newMethod->return_type;
					oldMethod->parameters = newMethod->parameters;
					oldMethod->parameters_count = newMethod->parameters_count;
					oldMethod->flags = newMethod->flags;
					oldMethod->iflags = newMethod->iflags;
					oldMethod->slot = newMethod->slot;
					oldMethod->token = newMethod->token;
					oldMethod->is_generic = newMethod->is_generic;
					oldMethod->is_inflated = newMethod->is_inflated;
					oldMethod->has_full_generic_sharing_signature = newMethod->has_full_generic_sharing_signature;
					oldMethod->isInterpterImpl = newMethod->isInterpterImpl;
					// methodMetadataHandle / genericContainerHandle share a union
					// with rgctx_data / genericMethod. For non-inflated method
					// definitions (the MonoBehaviour case) these hold the new
					// image's Il2CppMethodDefinition* — the field method resolution
					// compares by pointer identity, so it MUST be updated.
					oldMethod->methodMetadataHandle = newMethod->methodMetadataHandle;
					oldMethod->genericContainerHandle = newMethod->genericContainerHandle;

					// Restore declaring class to the reused Il2CppClass* and drop
					// any cached interpreter data so the body re-transforms from
					// this image's IL on next invocation.
					oldMethod->klass = oldKlass;
					oldMethod->interpData = nullptr;
				}
			}

			// Drop EVERY lazily-built cache derived from the previous image. The next
			// Class::Init(oldKlass) — which runs lazily, AFTER this image is registered
			// and the type is actually used (AddComponent / codegen InitFromCodegen /
			// il2cpp_codegen_initialize_runtime_metadata) — will rebuild them from this
			// image's metadata through the normal InitLocked sequence:
			//   SetupInterfaces -> SetupMethods -> SetupTypeHierarchy -> SetupVTable
			//   -> SetupFields -> SetupEvents -> SetupProperties -> SetupNestedTypes
			//   -> SetupGCDescriptor
			// i.e. EXACTLY how a freshly created Il2CppClass is initialized. This
			// guarantees the interface slot mapping (interfaceOffsets), the vtable and
			// the type hierarchy are fully consistent with the new metadata, fixing
			// interface dispatch (MethodAccessException "Attempt to access method ...
			// on type ... failed") after a dirty reload.
			//
			// We deliberately do NOT hand-rebuild interfaceOffsets / implementedInterfaces
			// / vtable here: a manual partial rebuild (done against a not-yet-registered
			// image, before the normal Init runs) can leave them subtly inconsistent
			// with the new image — which is precisely the bug observed on the second load.
			// Resetting the caches lets the battle-tested InitLocked path do the work.
			oldKlass->implementedInterfaces = nullptr;
			oldKlass->interfaceOffsets = nullptr;
			oldKlass->typeHierarchy = nullptr;
			oldKlass->properties = nullptr;
			oldKlass->events = nullptr;
			oldKlass->nestedTypes = nullptr;
			oldKlass->rgctx_data = nullptr;
			oldKlass->generic_class = nullptr;

			oldKlass->is_vtable_initialized = 0;
			oldKlass->initialized = 0;
			oldKlass->initialized_and_no_error = 0;
			oldKlass->init_pending = 0;
			oldKlass->initializationExceptionGCHandle = 0;

			reusedCount++;
		}
		il2cpp::utils::Logging::Write("[HybridCLR][DirtyReload] class reuse done: reused %u UnityEngine.Object-derived Il2CppClass* pointer(s).", reusedCount);
	}
