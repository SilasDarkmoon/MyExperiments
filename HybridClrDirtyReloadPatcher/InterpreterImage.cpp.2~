	// Compares the structural signature without constructing the new Il2CppClass.
	// Constructing a temporary newKlass resolves parent/declaring/element classes
	// through Class::FromIl2CppType before all reusable shells are published into
	// this image's _classList, which can pollute relationship/interface caches with
	// temporary Il2CppClass pointers. Keep this phase metadata-only.
	static bool IsClassStructurallyCompatible(Il2CppClass* oldKlass, const Il2CppTypeDefinition* newTypeDef, const Il2CppTypeDefinitionSizes* newTypeSizes)
	{
		if (oldKlass->field_count != newTypeDef->field_count)
			return false;
		if (oldKlass->method_count != newTypeDef->method_count)
			return false;
		if (oldKlass->vtable_count != newTypeDef->vtable_count)
			return false;
		if (oldKlass->interfaces_count != newTypeDef->interfaces_count)
			return false;
		if (oldKlass->interface_offsets_count != newTypeDef->interface_offsets_count)
			return false;
		if (oldKlass->instance_size != newTypeSizes->instance_size)
			return false;
		if (oldKlass->actualSize != newTypeSizes->instance_size)
			return false;

		const Il2CppTypeDefinition* oldTypeDef = (const Il2CppTypeDefinition*)oldKlass->typeMetadataHandle;

		for (uint16_t m = 0; m < oldKlass->method_count; m++)
		{
			const Il2CppMethodDefinition* om = il2cpp::vm::GlobalMetadata::GetMethodDefinitionFromIndex(oldTypeDef->methodStart + m);
			const Il2CppMethodDefinition* nm = il2cpp::vm::GlobalMetadata::GetMethodDefinitionFromIndex(newTypeDef->methodStart + m);
			if (!om || !nm)
				return false;
			const char* on = il2cpp::vm::GlobalMetadata::GetStringFromIndex(om->nameIndex);
			const char* nn = il2cpp::vm::GlobalMetadata::GetStringFromIndex(nm->nameIndex);
			if (!on || !nn)
				return false;
			if (std::strcmp(on, nn) != 0)
				return false;
			if (om->parameterCount != nm->parameterCount)
				return false;
			if (om->slot != nm->slot)
				return false;
		}

		return true;
	}

	struct DirtyReloadReusedClassInfo
	{
		Il2CppClass* klass;
		uint32_t rawIndex;
		const MethodInfo** oldMethods;
	};

	static std::vector<Il2CppClass*> s_dirtyReloadReusedClasses;

	void InterpreterImage::ReuseClassListFromPreviousLoad(Il2CppImage* il2cppImage)
	{
		// On dirty reload a fresh InterpreterImage is created with an all-null
		// _classList, so type lookups create brand-new Il2CppClass objects.
		// Unity native registers MonoBehaviour ScriptingClasses keyed by
		// Il2CppClass* and only scans each Il2CppImage* once. Because the
		// placeholder's Il2CppImage* is reused (Unity cached it at registration
		// time), Unity will not re-scan, leaving the new Il2CppClass objects
		// unregistered — AddComponent<MonoBehaviour>() returns null.
		//
		// Fix: for types derived from UnityEngine.Object (the ones Unity native
		// caches by Il2CppClass*), reuse the SAME Il2CppClass* from the previous
		// load so Unity's registrations remain valid — but ONLY when the type is
		// structurally unchanged (same fields, same method count). All other
		// types are dropped (left null) and re-created lazily from the new IL.
		//
		// Method bodies of reused classes still update: they are resolved through
		// klass->image->token which now points to this new InterpreterImage. We
		// clear the cached interpData so methods re-transform from the new IL.

		// Find the most recent previous InterpreterImage sharing the same Il2CppImage*.
		InterpreterImage* prev = nullptr;
		for (uint32_t i = 0; i < kMaxMetadataImageCount; i++)
		{
			InterpreterImage* img = s_images[i];
			if (!img || img == this)
				continue;
			if (img->_il2cppImage == il2cppImage && !img->_classList.empty())
			{
				if (!prev || img->_index > prev->_index)
					prev = img;
			}
		}
		if (!prev)
			return;

		// Reset lazy-built caches of ALL generic-instance Il2CppClass objects in
		// both the GenericClass and GenericMetadata module-level caches. These
		// Il2CppClass* are NOT in any InterpreterImage::_classList, so the per-
		// class reuse loop below does not touch them. After a dirty reload their
		// interfaceOffsets / implementedInterfaces still point at the previous
		// image's interface Il2CppClass* pointers, causing pointer-comparison
		// failures in GetInterfaceInvokeDataFromVTable -> MethodAccessException
		// on interface dispatch (e.g. IProgressPromise<float>.UpdateProgress on a
		// ProgressResult<float, IWindow> instance).
		il2cpp::vm::GenericClass::ResetGenericInstanceCaches(il2cppImage);
		il2cpp::metadata::GenericMetadata::ResetGenericInstanceCaches(il2cppImage);
		il2cpp::utils::Logging::Write("[HybridCLR][DirtyReload] generic instance caches reset.");

		// Reuse selectively, keyed by type full name (row index may differ across
		// versions when types are added/removed/reordered).
		//
		// NOTE: iterate over a snapshot of prev->_classList indices. prev is a
		// DIFFERENT container from this->_classList (which we mutate below), so
		// there is no iterator invalidation, but taking the size once keeps the
		// bound stable and makes the traversal obviously finite.
		il2cpp::utils::Logging::Write("[HybridCLR][DirtyReload] begin class reuse: prev image _index=%u, prev classes=%u",
			prev->_index, (uint32_t)prev->_classList.size());
		uint32_t reusedCount = 0;
		std::vector<DirtyReloadReusedClassInfo> reusedClasses;
		s_dirtyReloadReusedClasses.clear();
		for (size_t ci = 0, cn = prev->_classList.size(); ci < cn; ci++)
		{
			Il2CppClass* oldKlass = prev->_classList[ci];
			if (!oldKlass)
				continue;

			// Only reuse classes actually produced by prev's image. A reused
			// class stored in prev->_classList from an even earlier load would
			// have a different image; skip it to avoid touching foreign metadata.
			if (oldKlass->image != prev->_il2cppImage)
				continue;


			// Locate the same type (by namespace + name) in this (new) image.
			int32_t newRawIndex = -1;
			const char* oldNs = il2cpp::vm::Class::GetNamespace(oldKlass);
			const char* oldName = il2cpp::vm::Class::GetName(oldKlass);
			for (uint32_t i = 0, n = (uint32_t)_classList.size(); i < n; i++)
			{
				const Il2CppTypeDefinition* td = &_typesDefines[i];
				const char* ns = il2cpp::vm::GlobalMetadata::GetStringFromIndex(td->namespaceIndex);
				const char* nm = il2cpp::vm::GlobalMetadata::GetStringFromIndex(td->nameIndex);
				if (ns && nm && oldNs && oldName
					&& std::strcmp(ns, oldNs) == 0 && std::strcmp(nm, oldName) == 0)
				{
					newRawIndex = (int32_t)i;
					break;
				}
			}

			if (newRawIndex < 0)
			{
				// Type removed in the new version. Its old Il2CppClass* is leaked
				// (still referenced by Unity/GC), but it is no longer produced by
				// this image. Nothing to reuse.
				continue;
			}

			const Il2CppTypeDefinition* newTypeDef = &_typesDefines[newRawIndex];
			const Il2CppTypeDefinitionSizes* newTypeSizes = &_typeDetails[newRawIndex].typeSizes;

			// IMPORTANT: do NOT create or initialize a temporary newKlass here.
			// Creating one through GetTypeInfoFromTypeDefinitionRawIndex would call
			// GlobalMetadata::FromTypeDefinition, which resolves parent / declaring /
			// enum element classes immediately. During this first pass not all reused
			// shells have been published into _classList yet, so those relationships
			// could bind to temporary Il2CppClass pointers and later pollute interface
			// offsets, vtables or generic-instance caches.
			//
			// For reuse we only need metadata-level structural compatibility. Method
			// names / parameter counts / slots are read straight from the method
			// definitions, so no class/type relationship resolution happens here.
			if (!IsClassStructurallyCompatible(oldKlass, newTypeDef, newTypeSizes))
			{

				il2cpp::utils::Logging::Write(
					"[HybridCLR][DirtyReload] structural change detected for UnityEngine.Object-derived type '%s.%s'; discarding Il2CppClass reuse (Unity native cache may become stale).",
					oldNs ? oldNs : "", oldName ? oldName : "");
				// Do not create a replacement class here; leave the slot null so it can
				// be created lazily from the new metadata if it is ever requested.
				continue;
			}

			// Structurally compatible: reuse the old Il2CppClass* so Unity native
			// registrations (keyed by Il2CppClass*) stay valid. Rebind only pure
			// metadata-derived fields in this pass, publish the reused shell into the
			// new _classList immediately, and defer relationship resolution until all
			// reusable shells have been published.
			const MethodInfo** oldMethods = oldKlass->methods;
			_classList[newRawIndex] = oldKlass;

			oldKlass->image = _il2cppImage;
			oldKlass->name = il2cpp::vm::GlobalMetadata::GetStringFromIndex(newTypeDef->nameIndex);
			oldKlass->namespaze = il2cpp::vm::GlobalMetadata::GetStringFromIndex(newTypeDef->namespaceIndex);
			oldKlass->byval_arg = *il2cpp::vm::GlobalMetadata::GetIl2CppTypeFromIndex(newTypeDef->byvalTypeIndex);
			oldKlass->this_arg = oldKlass->byval_arg;
			oldKlass->this_arg.byref = true;
			oldKlass->this_arg.valuetype = 0;
			oldKlass->typeMetadataHandle = reinterpret_cast<const Il2CppMetadataTypeHandle>(newTypeDef);
			oldKlass->genericContainerHandle = il2cpp::vm::GlobalMetadata::GetGenericContainerFromIndex(newTypeDef->genericContainerIndex);
			oldKlass->flags = newTypeDef->flags;
			oldKlass->token = newTypeDef->token;
			oldKlass->method_count = newTypeDef->method_count;
			oldKlass->property_count = newTypeDef->property_count;
			oldKlass->field_count = newTypeDef->field_count;
			oldKlass->event_count = newTypeDef->event_count;
			oldKlass->nested_type_count = newTypeDef->nested_type_count;
			oldKlass->vtable_count = newTypeDef->vtable_count;
			oldKlass->interfaces_count = newTypeDef->interfaces_count;
			oldKlass->interface_offsets_count = newTypeDef->interface_offsets_count;
			oldKlass->klass = oldKlass;
			oldKlass->instance_size = newTypeSizes->instance_size;
			oldKlass->actualSize = newTypeSizes->instance_size;
			oldKlass->native_size = newTypeSizes->native_size;
			oldKlass->static_fields_size = newTypeSizes->static_fields_size;
			oldKlass->thread_static_fields_size = newTypeSizes->thread_static_fields_size;
			oldKlass->thread_static_fields_offset = -1;
			oldKlass->enumtype = (newTypeDef->bitfield >> (il2cpp::vm::kBitIsEnum - 1)) & 0x1;
			oldKlass->is_generic = newTypeDef->genericContainerIndex != kGenericContainerIndexInvalid;
			oldKlass->has_finalize = (newTypeDef->bitfield >> (il2cpp::vm::kBitHasFinalizer - 1)) & 0x1;
			oldKlass->has_cctor = (newTypeDef->bitfield >> (il2cpp::vm::kBitHasStaticConstructor - 1)) & 0x1;
			oldKlass->is_blittable = (newTypeDef->bitfield >> (il2cpp::vm::kBitIsBlittable - 1)) & 0x1;
			oldKlass->is_import_or_windows_runtime = (newTypeDef->bitfield >> (il2cpp::vm::kBitIsImportOrWindowsRuntime - 1)) & 0x1;
			oldKlass->packingSize = il2cpp::vm::GlobalMetadata::ConvertPackingSizeEnumToValue(static_cast<il2cpp::vm::PackingSize>((newTypeDef->bitfield >> (il2cpp::vm::kPackingSize - 1)) & 0xF));
			oldKlass->is_byref_like = (newTypeDef->bitfield >> (il2cpp::vm::kBitIsByRefLike - 1)) & 0x1;
			oldKlass->parent = nullptr;
			oldKlass->declaringType = nullptr;
			oldKlass->castClass = oldKlass;
			oldKlass->element_class = oldKlass;
			oldKlass->interopData = il2cpp::vm::MetadataCache::GetInteropDataForType(&oldKlass->byval_arg);
			oldKlass->stack_slot_size = 0;
			oldKlass->element_size = 0;
			oldKlass->typeHierarchyDepth = 0;
			oldKlass->genericRecursionDepth = 0;
			oldKlass->rank = 0;
			oldKlass->minimumAlignment = 0;
			oldKlass->nullabletype = 0;
			oldKlass->has_references = 0;


			// Rebuild FieldInfo later, after every reusable Il2CppClass shell has been
			// published into _classList. This prevents field array types from resolving
			// their element class to a temporary newKlass during this per-class pass.
			oldKlass->fields = nullptr;

			// Drop EVERY lazily-built cache derived from the previous image. The next
			// Class::Init(oldKlass) — which runs lazily, AFTER this image is registered
			// and the type is actually used (AddComponent / codegen InitFromCodegen /
			// il2cpp_codegen_initialize_runtime_metadata) — will rebuild them from this
			// image's metadata through the normal InitLocked sequence:
			//   SetupInterfaces -> SetupMethods -> SetupTypeHierarchy -> SetupVTable
			//   -> SetupFields -> SetupEvents -> SetupProperties -> SetupNestedTypes
			//   -> SetupGCDescriptor
			// i.e. EXACTLY how a freshly created Il2CppClass is initialized. This
			// guarantees the interface slot mapping (interfaceOffsets), the vtable and
			// the type hierarchy are fully consistent with the new metadata, fixing
			// interface dispatch (MethodAccessException "Attempt to access method ...
			// on type ... failed") after a dirty reload.
			//
			// We deliberately do NOT hand-rebuild interfaceOffsets / implementedInterfaces
			// / vtable here: a manual partial rebuild (done against a not-yet-registered
			// image, before the normal Init runs) can leave them subtly inconsistent
			// with the new image — which is precisely the bug observed on the second load.
			// Resetting the caches lets the battle-tested InitLocked path do the work.
			oldKlass->implementedInterfaces = nullptr;
			oldKlass->interfaceOffsets = nullptr;
			oldKlass->typeHierarchy = nullptr;
			oldKlass->properties = nullptr;
			oldKlass->events = nullptr;
			oldKlass->nestedTypes = nullptr;
			oldKlass->rgctx_data = nullptr;
			oldKlass->generic_class = nullptr;
			oldKlass->static_fields = nullptr;
			oldKlass->gc_desc = nullptr;

			oldKlass->is_vtable_initialized = 0;
			oldKlass->size_init_pending = 0;
			oldKlass->size_inited = 0;
			oldKlass->initialized = 0;
			oldKlass->initialized_and_no_error = 0;
			oldKlass->init_pending = 0;
			oldKlass->initializationExceptionGCHandle = 0;
			oldKlass->cctor_started = 0;
			oldKlass->cctor_finished_or_no_cctor = !oldKlass->has_cctor;
			oldKlass->cctor_thread = 0;

			reusedClasses.push_back({ oldKlass, (uint32_t)newRawIndex, oldMethods });
			s_dirtyReloadReusedClasses.push_back(oldKlass);
			reusedCount++;
		}

		for (const DirtyReloadReusedClassInfo& info : reusedClasses)
		{
			Il2CppClass* oldKlass = info.klass;
			const Il2CppTypeDefinition* typeDef = &_typesDefines[info.rawIndex];
			if (typeDef->parentIndex != kTypeIndexInvalid)
				oldKlass->parent = il2cpp::vm::Class::FromIl2CppType(il2cpp::vm::GlobalMetadata::GetIl2CppTypeFromIndex(typeDef->parentIndex));
			if (typeDef->declaringTypeIndex != kTypeIndexInvalid)
				oldKlass->declaringType = il2cpp::vm::Class::FromIl2CppType(il2cpp::vm::GlobalMetadata::GetIl2CppTypeFromIndex(typeDef->declaringTypeIndex));
			oldKlass->castClass = oldKlass->element_class = oldKlass;
			if (oldKlass->enumtype)
				oldKlass->castClass = oldKlass->element_class = il2cpp::vm::Class::FromIl2CppType(il2cpp::vm::GlobalMetadata::GetIl2CppTypeFromIndex(typeDef->elementTypeIndex));
		}

		uint32_t rebuiltFieldCount = 0;
		for (const DirtyReloadReusedClassInfo& info : reusedClasses)
		{
			Il2CppClass* oldKlass = info.klass;
			// Now that all reusable class shells have been published into this image's
			// _classList and relationship pointers have been remapped, rebuild fields
			// through the normal metadata path. Field array types now resolve their
			// element class to the reused oldKlass shell instead of a temporary newKlass.
			il2cpp::vm::Class::SetupFields(oldKlass);
			rebuiltFieldCount++;
		}

		// Fields for every reused class are now rebuilt, so array element classes
		// resolve to the published oldKlass shells instead of the temporary newKlass
		// objects. Deferring SetupMethods to here (rather than during the per-class
		// pass) keeps method parameter/return-type resolution from creating
		// ArrayMetadata entries that reference temporary newKlass objects. The old
		// MethodInfo* objects are still reused (pointer identity preserved for any
		// cached reference); only their contents are rebound to this image's pool.
		uint32_t reboundMethodCount = 0;
		for (const DirtyReloadReusedClassInfo& info : reusedClasses)
		{
			Il2CppClass* oldKlass = info.klass;
			const MethodInfo** oldMethods = info.oldMethods;

			oldKlass->methods = nullptr;
			il2cpp::vm::Class::SetupMethods(oldKlass);

			// The structural-compatibility check guarantees identical method count
			// and per-index correspondence (same name / parameter count / slot).
			// Keep the old MethodInfo* objects when they already exist, but rebind
			// their contents from the newly rebuilt metadata-derived MethodInfo array.
			if (oldMethods && oldKlass->methods)
			{
				const MethodInfo** newMethods = oldKlass->methods;
				for (uint16_t m = 0; m < oldKlass->method_count; m++)
				{
					MethodInfo* oldMethod = const_cast<MethodInfo*>(oldMethods[m]);
					const MethodInfo* newMethod = newMethods[m];
					if (!oldMethod || !newMethod)
						continue;

					oldMethod->methodPointer = newMethod->methodPointer;
					oldMethod->virtualMethodPointer = newMethod->virtualMethodPointer;
					oldMethod->methodPointerCallByInterp = newMethod->methodPointerCallByInterp;
					oldMethod->virtualMethodPointerCallByInterp = newMethod->virtualMethodPointerCallByInterp;
					oldMethod->initInterpCallMethodPointer = newMethod->initInterpCallMethodPointer;
					oldMethod->invoker_method = newMethod->invoker_method;
					oldMethod->name = newMethod->name;
					oldMethod->return_type = newMethod->return_type;
					oldMethod->parameters = newMethod->parameters;
					oldMethod->parameters_count = newMethod->parameters_count;
					oldMethod->flags = newMethod->flags;
					oldMethod->iflags = newMethod->iflags;
					oldMethod->slot = newMethod->slot;
					oldMethod->token = newMethod->token;
					oldMethod->is_generic = newMethod->is_generic;
					oldMethod->is_inflated = newMethod->is_inflated;
					oldMethod->has_full_generic_sharing_signature = newMethod->has_full_generic_sharing_signature;
					oldMethod->isInterpterImpl = newMethod->isInterpterImpl;
					oldMethod->methodMetadataHandle = newMethod->methodMetadataHandle;
					oldMethod->genericContainerHandle = newMethod->genericContainerHandle;
					oldMethod->klass = oldKlass;
					oldMethod->interpData = nullptr;
					oldKlass->methods[m] = oldMethod;
				}
			}
			reboundMethodCount++;
		}

		il2cpp::vm::GenericClass::ResetGenericInstanceCaches(il2cppImage);
		il2cpp::metadata::GenericMetadata::ResetGenericInstanceCaches(il2cppImage);
		il2cpp::utils::Logging::Write("[HybridCLR][DirtyReload] generic instance caches reset after class rebind.");

		il2cpp::utils::Logging::Write("[HybridCLR][DirtyReload] class reuse done: reused %u Il2CppClass* pointer(s), rebuilt fields for %u class(es), rebound methods for %u class(es). Eager init is deferred until after assembly registration.", reusedCount, rebuiltFieldCount, reboundMethodCount);


	}

	void InterpreterImage::EagerInitDirtyReloadReusedClasses()
	{
		uint32_t initializedCount = 0;
		for (Il2CppClass* klass : s_dirtyReloadReusedClasses)
		{
			if (!klass)
				continue;
			il2cpp::vm::Class::Init(klass);
			initializedCount++;
		}
		if (initializedCount > 0)
			il2cpp::utils::Logging::Write("[HybridCLR][DirtyReload] eagerly initialized %u reused class(es) after assembly registration.", initializedCount);
		s_dirtyReloadReusedClasses.clear();
	}
