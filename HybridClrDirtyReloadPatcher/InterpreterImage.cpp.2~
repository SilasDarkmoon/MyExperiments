	void InterpreterImage::ReuseClassListFromPreviousLoad(Il2CppImage* il2cppImage)
	{
		// On dirty reload a fresh InterpreterImage is created with an all-null
		// _classList, so type lookups create brand-new Il2CppClass objects.
		// Unity native registers MonoBehaviour ScriptingClasses keyed by
		// Il2CppClass* and only scans each Il2CppImage* once. Because the
		// placeholder's Il2CppImage* is reused (Unity cached it at registration
		// time), Unity will not re-scan, leaving the new Il2CppClass objects
		// unregistered — AddComponent<MonoBehaviour>() returns null.
		//
		// Fix: for every type that also existed in the previous load (matched by
		// namespace + name) REUSE the SAME Il2CppClass* so Unity's registrations
		// stay valid. We deliberately do NOT build any temporary newKlass: a
		// newKlass would leak its pointer into metadata caches (the type pool,
		// vtable, interface-offset maps, and parent/element/declaring chains) and
		// cause type confusion. Instead we re-derive the reused class's shell
		// straight from THIS image's metadata and then let the built-in
		// Class::Init path fully (re)build methods / fields / interfaces / vtable
		// / GC descriptor from the new IL.
		//
		// Crucial ordering: ALL reusable shells are published into this image's
		// _classList FIRST. Only then do we derive each shell's metadata (phase 2).
		// Because the shells are already published, relationship resolution
		// (parent / element / declaring / cast) walks this image's _classList and
		// lands on the reused shells — never on a temporary class — so the deferred
		// Class::Init (phase 3) walks a fully consistent hierarchy.
		// so no manual remap pass is needed.

		// Find the most recent previous InterpreterImage sharing the same Il2CppImage*.
		InterpreterImage* prev = nullptr;
		for (uint32_t i = 0; i < kMaxMetadataImageCount; i++)
		{
			InterpreterImage* img = s_images[i];
			if (!img || img == this)
				continue;
			if (img->_il2cppImage == il2cppImage && !img->_classList.empty())
			{
				if (!prev || img->_index > prev->_index)
					prev = img;
			}
		}
		if (!prev)
			return;

		// Drop every cached method body that belongs to the previous image. Those
		// MethodBody entries point at the previous load's IL blob; keeping them in
		// the global MethodBodyCache would let the shrink pass (ShrinkMethodBodyCache)
		// destruct them later — and if the previous image's metadata is ever released
		// that becomes a use-after-free. Clearing here guarantees the new image
		// re-transforms method bodies from its own IL on demand.
		hybridclr::metadata::MethodBodyCache::ClearImage(prev);

		// Reuse is keyed by type full name (row index may differ across versions
		// when types are added/removed/reordered).
		//
		// NOTE: iterate over a snapshot of prev->_classList indices. prev is a
		// DIFFERENT container from this->_classList (which we mutate below), so
		// there is no iterator invalidation, but taking the size once keeps the
		// bound stable and makes the traversal obviously finite.
		il2cpp::utils::Logging::Write("[HybridCLR][DirtyReload] begin class reuse: prev image _index=%u, prev classes=%u",
			prev->_index, (uint32_t)prev->_classList.size());

		// Phase 1: publish every reusable Il2CppClass* shell into this image's
		// _classList. Only the pointer is relocated here — no class contents are
		// touched yet, so relationship resolution during the later derive pass
		// finds the reused shell instead of building a fresh class.
		std::vector<std::pair<Il2CppClass*, uint32_t>> reused;   // (oldKlass, newRawIndex)
		for (size_t ci = 0, cn = prev->_classList.size(); ci < cn; ci++)
		{
			Il2CppClass* oldKlass = prev->_classList[ci];
			if (!oldKlass)
				continue;

			// Only reuse classes actually produced by prev's image. A reused
			// class stored in prev->_classList from an even earlier load would
			// have a different image; skip it to avoid touching foreign metadata.
			if (oldKlass->image != prev->_il2cppImage)
				continue;

			// Locate the same type (by namespace + name) in this (new) image.
			int32_t newRawIndex = -1;
			const char* oldNs = il2cpp::vm::Class::GetNamespace(oldKlass);
			const char* oldName = il2cpp::vm::Class::GetName(oldKlass);
			for (uint32_t i = 0, n = (uint32_t)_classList.size(); i < n; i++)
			{
				const Il2CppTypeDefinition* td = &_typesDefines[i];
				const char* ns = il2cpp::vm::GlobalMetadata::GetStringFromIndex(td->namespaceIndex);
				const char* nm = il2cpp::vm::GlobalMetadata::GetStringFromIndex(td->nameIndex);
				if (ns && nm && oldNs && oldName
					&& std::strcmp(ns, oldNs) == 0 && std::strcmp(nm, oldName) == 0)
				{
					newRawIndex = (int32_t)i;
					break;
				}
			}

			if (newRawIndex < 0)
			{
				// Type removed in the new version. Its old Il2CppClass* is leaked
				// (still referenced by Unity/GC), but it is no longer produced by
				// this image. Nothing to reuse.
				continue;
			}

			// Publish the reused shell in the NEW image. Relationship pointers of
			// other reused classes will resolve to this object once derived.
			_classList[newRawIndex] = oldKlass;
			reused.push_back({ oldKlass, (uint32_t)newRawIndex });
		}

		// Phase 2: re-derive each reused shell's metadata from THIS image, using
		// the same built-in metadata reads that il2cpp's GlobalMetadata::
		// FromTypeDefinition uses, and reset every lazily-built cache so the
		// normal Init path rebuilds them. Relationship pointers are resolved
		// through Class::FromIl2CppType, which now lands on the reused shells
		// published above (no newKlass involved).
		for (auto& pr : reused)
		{
			Il2CppClass* oldKlass = pr.first;
			uint32_t newRawIndex = pr.second;
			const Il2CppTypeDefinition* td = &_typesDefines[newRawIndex];
			const Il2CppTypeDefinitionSizes* tds =
				hybridclr::metadata::MetadataModule::GetTypeDefinitionSizesFromEncodeIndex(EncodeWithIndex(newRawIndex));

			// --- FromTypeDefinition-level shell data, sourced from the new image ---
			oldKlass->image = _il2cppImage;
			oldKlass->name = il2cpp::vm::GlobalMetadata::GetStringFromIndex(td->nameIndex);
			oldKlass->namespaze = il2cpp::vm::GlobalMetadata::GetStringFromIndex(td->namespaceIndex);
			oldKlass->byval_arg = *il2cpp::vm::GlobalMetadata::GetIl2CppTypeFromIndex(td->byvalTypeIndex);
			oldKlass->this_arg = oldKlass->byval_arg;
			oldKlass->this_arg.byref = true;
			oldKlass->this_arg.valuetype = 0;
			oldKlass->typeMetadataHandle = reinterpret_cast<const Il2CppMetadataTypeHandle>(td);
			oldKlass->genericContainerHandle = il2cpp::vm::GlobalMetadata::GetGenericContainerFromIndex(td->genericContainerIndex);
			oldKlass->instance_size = tds->instance_size;
			oldKlass->actualSize = tds->instance_size;
			oldKlass->native_size = tds->native_size;
			oldKlass->static_fields_size = tds->static_fields_size;
			oldKlass->thread_static_fields_size = tds->thread_static_fields_size;
			oldKlass->thread_static_fields_offset = -1;
			oldKlass->flags = td->flags;
			oldKlass->enumtype = (td->bitfield >> (il2cpp::vm::kBitIsEnum - 1)) & 0x1;
			oldKlass->is_generic = td->genericContainerIndex != kGenericContainerIndexInvalid;
			oldKlass->has_finalize = (td->bitfield >> (il2cpp::vm::kBitHasFinalizer - 1)) & 0x1;
			oldKlass->has_cctor = (td->bitfield >> (il2cpp::vm::kBitHasStaticConstructor - 1)) & 0x1;
			oldKlass->cctor_finished_or_no_cctor = !oldKlass->has_cctor;
			oldKlass->is_blittable = (td->bitfield >> (il2cpp::vm::kBitIsBlittable - 1)) & 0x1;
			oldKlass->is_import_or_windows_runtime = (td->bitfield >> (il2cpp::vm::kBitIsImportOrWindowsRuntime - 1)) & 0x1;
			oldKlass->packingSize = il2cpp::vm::GlobalMetadata::ConvertPackingSizeEnumToValue(
				static_cast<il2cpp::vm::PackingSize>((td->bitfield >> (il2cpp::vm::kPackingSize - 1)) & 0xF));
			oldKlass->is_byref_like = (td->bitfield >> (il2cpp::vm::kBitIsByRefLike - 1)) & 0x1;
			oldKlass->method_count = td->method_count;
			oldKlass->property_count = td->property_count;
			oldKlass->field_count = td->field_count;
			oldKlass->event_count = td->event_count;
			oldKlass->nested_type_count = td->nested_type_count;
			oldKlass->vtable_count = td->vtable_count;
			oldKlass->interfaces_count = td->interfaces_count;
			oldKlass->interface_offsets_count = td->interface_offsets_count;
			oldKlass->token = td->token;
			oldKlass->interopData = il2cpp::vm::MetadataCache::GetInteropDataForType(&oldKlass->byval_arg);

			// Relationship pointers via the built-in path. A parent / declaring /
			// element type that is also reused resolves to the reused shell.
			oldKlass->parent = (td->parentIndex != kTypeIndexInvalid)
				? il2cpp::vm::Class::FromIl2CppType(il2cpp::vm::GlobalMetadata::GetIl2CppTypeFromIndex(td->parentIndex))
				: nullptr;
			oldKlass->declaringType = (td->declaringTypeIndex != kTypeIndexInvalid)
				? il2cpp::vm::Class::FromIl2CppType(il2cpp::vm::GlobalMetadata::GetIl2CppTypeFromIndex(td->declaringTypeIndex))
				: nullptr;
			oldKlass->castClass = oldKlass->element_class = oldKlass;
			if (oldKlass->enumtype)
				oldKlass->castClass = oldKlass->element_class =
					il2cpp::vm::Class::FromIl2CppType(il2cpp::vm::GlobalMetadata::GetIl2CppTypeFromIndex(td->elementTypeIndex));

			// --- reset every lazily-built cache so Class::Init rebuilds from new ---
			oldKlass->fields = nullptr;
			oldKlass->methods = nullptr;
			oldKlass->implementedInterfaces = nullptr;
			oldKlass->interfaceOffsets = nullptr;
			oldKlass->typeHierarchy = nullptr;
			oldKlass->properties = nullptr;
			oldKlass->events = nullptr;
			oldKlass->nestedTypes = nullptr;
			oldKlass->rgctx_data = nullptr;
			oldKlass->static_fields = nullptr;
			oldKlass->gc_desc = nullptr;
			oldKlass->has_references = 0;
			oldKlass->minimumAlignment = 0;
			oldKlass->typeHierarchyDepth = 0;
			oldKlass->element_size = 0;
			oldKlass->stack_slot_size = 0;
			oldKlass->nullabletype = 0;
			oldKlass->genericRecursionDepth = 0;
			oldKlass->rank = 0;
			oldKlass->is_vtable_initialized = 0;
			oldKlass->size_init_pending = 0;
			oldKlass->size_inited = 0;
			oldKlass->initialized = 0;
			oldKlass->initialized_and_no_error = 0;
			oldKlass->init_pending = 0;
			oldKlass->initializationExceptionGCHandle = 0;
			oldKlass->cctor_started = 0;
			oldKlass->cctor_thread = 0;
		}

		// Phase 3: the class CONTENTS (methods / fields / interfaces / vtable / GC
		// descriptor) are NOT built here. We deliberately keep the lazily-built
		// caches reset (done in phase 2) and let il2cpp's normal, battle-tested
		// Class::Init path rebuild them from THIS image's IL on first real use —
		// i.e. AFTER this image is registered (RegisterInterpreterAssembly runs
		// immediately after ReuseClassListFromPreviousLoad returns). Eagerly calling
		// Class::Init here, inside Assembly::Create, would run static constructors
		// before the image is visible to the metadata subsystem and re-enter
		// Transform / MethodBodyCache (the exact shrink path that just crashed),
		// which can corrupt the global method-body cache. The deferred path avoids
		// that re-entrancy entirely while still using the built-in init functions.
		//
		// Because every reusable shell was published in phase 1 and its relationship
		// pointers were re-derived (via Class::FromIl2CppType) onto those reused
		// shells in phase 2, the deferred Class::Init walks a fully consistent
		// parent / element / declaring chain — so interface dispatch, the vtable and
		// the type hierarchy are correct without any manual partial rebuild.

		il2cpp::utils::Logging::Write("[HybridCLR][DirtyReload] class reuse done: reused %u Il2CppClass* pointer(s); content rebuild deferred to first use via Class::Init.",
			(uint32_t)reused.size());
	}
